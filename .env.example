# Copie en ".env" pour tester en local (ne pas committer).
SEC_USER_AGENT="PE Watcher ton.email@exemple.com"

# LLM compatible OpenAI (exemple Groq, free tier) :
LLM_API_URL="https://api.groq.com/openai/v1/chat/completions"
LLM_API_KEY="gsk_..."
LLM_MODEL="llama-3.3-70b-versatile"

# Email via Brevo (facultatif : sans ces 3 lignes, pas d'email, juste le site)
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM="expediteur-verifie@tondomaine.com"
EMAIL_TO="ton.email@exemple.com"

# Nombre max de depots analyses par passage (budget LLM)
MAX_ANALYZE="3"
